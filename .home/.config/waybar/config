{
    "layer": "top",
    "position": "top",
    "reload_style_on_change": true,
    "modules-left": [
        "custom/notification",
        "clock",
        "custom/pacman"
    ],
    "modules-center": [
        "hyprland/workspaces"
    ],
    "modules-right": [
        "cpu",
        "memory",
        "temperature",
        "custom/endpoint",
        "pulseaudio",
        "bluetooth",
        "tray",
        "battery"
    ],
    "sni-tray": {
        "excluded": [
            "blueman-applet"
        ]
    },
    "hyprland/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "active": "ï„‘",
            "default": "ï„‘",
            "empty": "ï„‘"
        },
        "persistent-workspaces": {
            "*": [
                1,
                2,
                3,
                4,
                5
            ]
        }
    },
    "custom/notification": {
        "tooltip": false,
        "format": "îڑگ",
        "on-click": "swaync-client -t -sw",
        "escape": true
    },
    "clock": {
        "format": "{:%H:%M} ",
        "interval": 1,
        "tooltip-format": "<tt>{calendar}</tt>",
        "calendar": {
            "format": {
                "today": "<span color='#fAfBfC'><b>{}</b></span>"
            }
        },
        "actions": {
            "on-click-right": "shift_down",
            "on-click": "shift_up"
        }
    },
    "bluetooth": {
        "format-on": "َ°‚¯",
        "format-off": "BT-off",
        "format-disabled": "َ°‚²",
        "format-connected": "َ°‚¯",
        "format-connected-battery": "{device_battery_percentage}% َ°‚¯",
        "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
        "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\n{device_address}",
        "tooltip-format-enumerate-connected-battery": "{device_alias}\n{device_address}\n{device_battery_percentage}%",
        "on-click-right": "hyprctl dispatch exec blueman-manager"
    },
    "battery": {
        "interval": 30,
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 20
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% َ°‚„",
        "format-plugged": "{capacity}% َ°‚„ î¬­",
        "format-alt": "{time} {icon}",
        "format-icons": [
            "َ°پ»",
            "َ°پ¼",
            "َ°پ¾",
            "َ°‚€",
            "َ°‚‚",
            "َ°پ¹"
        ]
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "َ°‌ں {volume}%",
        "format-icons": {
            "default": [
                "َ°•؟",
                "َ°–€",
                "َ°•¾"
            ],
            "headphone": "َ°‹‹",
            "headset": "َ°‹‹"
        },
        "tooltip-format": "Device: {desc}",
        "on-click": "~/.config/waybar/scripts/volume-control.sh -g g",
        "on-click-middle": "~/.config/waybar/scripts/volume-control.sh -o m",
        "on-scroll-up": "~/.config/waybar/scripts/volume-control.sh -o i",
        "on-scroll-down": "~/.config/waybar/scripts/volume-control.sh -o d",
        "min-length": 6,
        "max-length": 6
    },
    "custom/pacman": {
        "format": "َ°…¢  {}",
        "interval": 30,
        "exec": "checkupdates | wc -l",
        "exec-if": "exit 0",
        "on-click": "kitty sh -c 'yay -Syu; echo Done - Press enter to exit; read'; pkill -SIGRTMIN+8 waybar",
        "signal": 8,
        "tooltip": false
    },
    "custom/expand": {
        "format": "ï„„",
        "tooltip": false
    },
    "custom/endpoint": {
        "format": "|",
        "tooltip": false
    },
    "cpu": {
        "format": "ï‹› {usage}%",
        "tooltip": true
    },
    "memory": {
        "format": "î؟… {percentage}%"
    },
    "temperature": {
        "format": "ï‹‰ {temperatureC}آ°C",
        "critical-threshold": 80
    }
}
