# ===============
# === Folders ===
# ===============
alias thcr='cd ~/Documents/thcr'
alias konolico='cd ~/Documents/konolico'
alias av='cd ~/Documents/av'
alias ufst='cd ~/Documents/ufst'

# ===============
# === Helpers ===
# ===============
alias c='clear'
alias ls='ls -A'

swiss() { # $1 node to use
  if [ -n "$1" ]; then
    kubectl run tmp-shell --rm -it \
      --overrides='{"spec":{"nodeSelector":{"kubernetes.io/hostname":"'"$1"'"}}}' \
      --image nicolaka/netshoot -- /bin/zsh
  else
    kubectl run tmp-shell --rm -it \
      --image nicolaka/netshoot -- /bin/zsh
  fi
}

# ================
# === Programs ===
# ================
alias g='git'
alias vi='git'
alias htop='btop'
alias k='kubectl'
alias kn='kubens'
alias kubectl='kubecolor'
alias kx='kubectx'
alias less='bat'
alias ls='exa -la'
alias tf='tfswitch && terraform'
alias find='fd'
